# Panel de Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Solo se usa en el servidor (API routes) para crear usuarios dentistas
# y resetear contraseñas. NUNCA exponerla al cliente.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Meta for Developers > tu app > WhatsApp > API Setup
WHATSAPP_TOKEN=tu-token-de-acceso-de-whatsapp
WHATSAPP_PHONE_NUMBER_ID=tu-phone-number-id
# Cualquier cadena que tú inventes; la usas también al configurar el webhook en Meta.
WHATSAPP_VERIFY_TOKEN=inventa-una-cadena-secreta-aqui

# URL pública de tu app (para que los links de "Agendar cita" funcionen dentro de WhatsApp)
NEXT_PUBLIC_SITE_URL=https://tu-dominio.vercel.app
